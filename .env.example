# Copy this file to .env and fill in as needed. The app runs fully with just DATABASE_URL.

# Local SQLite database (single file — back this up by copying it).
DATABASE_URL="file:./prisma/dev.db"

# --- Optional enrichment (all off by default) ---

# Google Street View Static API key. Leave blank to disable Street View enrichment.
GOOGLE_MAPS_API_KEY=""

# Master switch for the Street View fallback image. "true" to enable (also needs a key above).
STREETVIEW_ENABLED="false"

# Contact email sent to Nominatim per its geocoding usage policy. Optional but polite.
NOMINATIM_CONTACT_EMAIL=""

# --- Auth gate (PRODUCTION) ---
# Leave both BLANK for local dev (the app stays open). In production BOTH are
# required — the container refuses to start without them.
#
# Shared password you and your partner type to log in.
APP_PASSWORD=""
# Long random string used to sign the session cookie. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=""
